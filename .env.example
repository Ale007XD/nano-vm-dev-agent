# nano-vm-dev-agent environment variables
# Copy this file to .env and fill in your values

# ---------------------------------------------------------------------------
# LLM Provider — set ONE of the following API keys.
# Provider resolution order (first configured key wins):
#   1. Vibecode proxy  — VIBECODE_API_KEY
#   2. OpenRouter      — OPENROUTER_API_KEY  (free tier available)
#   3. Anthropic API   — ANTHROPIC_API_KEY
#
# Override explicitly: NANO_VM_AGENT_PROVIDER=vibecode|openrouter|anthropic
# Override model:      NANO_VM_AGENT_MODEL=<litellm model string>
# ---------------------------------------------------------------------------

# Vibecode proxy (OpenAI-compatible, claude-sonnet-4.6)
# VIBECODE_API_KEY=sk-...

# OpenRouter — free tier models available, get key at https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-...

# Anthropic API direct
# ANTHROPIC_API_KEY=sk-ant-...

# ---------------------------------------------------------------------------
# Explicit provider override (optional — auto-detected from keys if unset)
# ---------------------------------------------------------------------------
# NANO_VM_AGENT_PROVIDER=openrouter

# Model override (optional — each provider has a sensible default)
# Vibecode default:    openai/claude-sonnet-4.6
# OpenRouter defaults: openrouter/meta-llama/llama-3.3-70b-instruct:free
#                      openrouter/google/gemma-3-27b-it:free
#                      openrouter/qwen/qwen-2.5-72b-instruct:free
# Anthropic default:   claude-sonnet-4-20250514
# NANO_VM_AGENT_MODEL=openrouter/meta-llama/llama-3.3-70b-instruct:free

# ---------------------------------------------------------------------------
# Repository paths (used in runner.py repo_path argument)
# ---------------------------------------------------------------------------
NANO_VM_REPO_PATH=/path/to/nano_vm
NANO_VM_MCP_REPO_PATH=/path/to/nano-vm-mcp
