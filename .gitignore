# Байт-код Python (спрессованные файлы скомпилированного кода)
__pycache__/
*.py[cod]
*$py.class

# Виртуальные окружения (локальные папки зависимостей)
.venv/
venv/
ENV/
env/

# Файлы конфигурации и секреты (переменные окружения)
.env
.env.local
*.secrets

# Расширения C (если компилируете модули)
*.so

# Логи и отчеты об ошибках
*.log
crashplan_heavy_dump

# Папки сборки и дистрибутивов (при создании пакетов)
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg

# Настройки сред разработки (PyCharm, VS Code)
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# Тестирование и покрытие кода
.toml
.cache
.pytest_cache/
.coverage
htmlcov/
nosetests.xml
coverage.xml
*.coverage.*

# Jupyter Notebook (контрольные точки)
.ipynb_checkpoints

# Данные и базы данных (локальные копии)
*.db
*.sqlite3
